<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AkademiTrack.ViewModels"
             xmlns:services="using:AkademiTrack.Services"
             mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="600"
             x:Class="AkademiTrack.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <UserControl.Resources>
        <vm:TimeToPositionConverter x:Key="TimeToPositionConverter"/>
        <vm:DurationToHeightConverter x:Key="DurationToHeightConverter"/>
        <vm:TimeFormatConverter x:Key="TimeFormatConverter"/>
        <vm:TimeToMarginConverter x:Key="TimeToMarginConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.view-toggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.view-toggle.active">
            <Setter Property="Background" Value="#5B9BFF"/>
            <Setter Property="BorderBrush" Value="#5B9BFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.view-toggle:pointerover">
            <Setter Property="Background" Value="#1A5B9BFF"/>
        </Style>

        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.nav-button:pointerover">
            <Setter Property="Background" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"/>
        </Style>

        <Style Selector="Border.session-card">
            <Setter Property="Background" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBackground}"/>
            <Setter Property="BorderBrush" Value="#5B9BFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <Style Selector="Border.session-card.month">
            <Setter Property="Background" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBackground}"/>
            <Setter Property="BorderBrush" Value="#5B9BFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <Style Selector="Border.session-card.month.stu">
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>

        <Style Selector="Border.session-card.stu">
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>

        <Style Selector="TextBlock.day-number">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"/>
        </Style>

        <Style Selector="TextBlock.day-number.other-month">
            <Setter Property="Foreground" Value="#666666"/>
        </Style>

        <Style Selector="TextBlock.day-number.today">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5B9BFF"/>
        </Style>

        <Style Selector="TextBlock.session-subject">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"/>
        </Style>

        <Style Selector="TextBlock.session-time">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"/>
        </Style>

        <Style Selector="TextBlock.session-room">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Controls -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- View Toggle Buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Classes="view-toggle" 
                        Classes.active="{Binding IsMonthView}"
                        Content="Måned"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).SetViewCommand}"
                        CommandParameter="Måned"/>
                <Button Classes="view-toggle"
                        Classes.active="{Binding IsWeekView}"
                        Content="Uke"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).SetViewCommand}"
                        CommandParameter="Uke"/>
                <Button Classes="view-toggle"
                        Classes.active="{Binding IsDayView}"
                        Content="Dag"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).SetViewCommand}"
                        CommandParameter="Dag"/>
            </StackPanel>

            <!-- Date Display -->
            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayDateRange}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Navigation Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Classes="nav-button"
                        Content="◀"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).NavigatePreviousCommand}"/>
                <Button Classes="nav-button"
                        Content="I dag"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).NavigateTodayCommand}"/>
                <Button Classes="nav-button"
                        Content="▶"
                        Command="{Binding $parent[UserControl].((vm:CalendarViewModel)DataContext).NavigateNextCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Calendar Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Week View with time-based positioning -->
                <Grid IsVisible="{Binding IsWeekView}" MinHeight="600">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Day headers and content -->
                    <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Day headers -->
                        <ItemsControl Grid.Row="0" Grid.ColumnSpan="5" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CalendarDayData">
                                    <Border BorderBrush="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"
                                            BorderThickness="1,0,0,1"
                                            Padding="4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DayName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"/>
                                            <TextBlock Text="{Binding DayNumber}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Day columns -->
                        <ItemsControl Grid.Row="1" Grid.ColumnSpan="5" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CalendarDayData">
                                    <Border BorderBrush="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"
                                            BorderThickness="1,0,0,0"
                                            Padding="4,0">
                                        <!-- All sessions grouped by exact time -->
                                        <ItemsControl ItemsSource="{Binding GroupedSessions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:SessionGroup">
                                                    <StackPanel>
                                                        <!-- Add spacing before this group based on actual gap duration -->
                                                        <Border Height="{Binding GapHeight}"/>
                                                        
                                                        <!-- Sessions with same exact time displayed horizontally -->
                                                        <ItemsControl ItemsSource="{Binding Sessions}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Rows="1"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="services:ScheduleItem">
                                                                    <Border Classes="session-card"
                                                                            Classes.stu="{Binding IsStu}"
                                                                            ToolTip.Tip="{Binding DisplayName}"
                                                                            Margin="2,1"
                                                                            Height="50">
                                                                        <StackPanel>
                                                                            <TextBlock Classes="session-subject"
                                                                                       Text="{Binding DisplayName}"
                                                                                       TextWrapping="Wrap"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       MaxLines="2"/>
                                                                            <TextBlock Classes="session-time" Margin="0,2,0,0">
                                                                                <Run Text="{Binding StartKl, Converter={StaticResource TimeFormatConverter}}"/>
                                                                                <Run Text="-"/>
                                                                                <Run Text="{Binding SluttKl, Converter={StaticResource TimeFormatConverter}}"/>
                                                                            </TextBlock>
                                                                            <TextBlock Classes="session-room"
                                                                                       Text="{Binding Romnr}"
                                                                                       IsVisible="{Binding Romnr, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>

                <!-- Day View -->
                <StackPanel IsVisible="{Binding IsDayView}" Spacing="0">
                    <ItemsControl ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:CalendarDayData">
                                <ItemsControl ItemsSource="{Binding GroupedSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:SessionGroup">
                                            <StackPanel>
                                                <!-- Add spacing before this group based on actual gap duration -->
                                                <Border Height="{Binding GapHeight}"/>
                                                
                                                <!-- Sessions with same exact time displayed horizontally -->
                                                <ItemsControl ItemsSource="{Binding Sessions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="1"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="services:ScheduleItem">
                                                            <Border Classes="session-card"
                                                                    Classes.stu="{Binding IsStu}"
                                                                    Margin="2"
                                                                    Padding="12,8"
                                                                    Height="50">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0" Width="80" Margin="0,0,16,0">
                                                                        <TextBlock Classes="session-time" FontWeight="SemiBold" FontSize="12"
                                                                                   Text="{Binding StartKl, Converter={StaticResource TimeFormatConverter}}"/>
                                                                        <TextBlock Classes="session-time" FontSize="12"
                                                                                   Text="{Binding SluttKl, Converter={StaticResource TimeFormatConverter}}"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Classes="session-subject"
                                                                                   Text="{Binding DisplayName}"
                                                                                   FontSize="14"/>
                                                                        <TextBlock Classes="session-room"
                                                                                   Text="{Binding Romnr, StringFormat='Rom {0}'}"
                                                                                   IsVisible="{Binding Romnr, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                                   Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Month View -->
                <Grid IsVisible="{Binding IsMonthView}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Month header with day names -->
                    <Grid Grid.Row="0" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="MAN" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="TIR" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="ONS" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="TOR" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="FRE" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="LØR" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="SØN" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Calendar grid -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:CalendarDayData">
                                <Border BorderBrush="{Binding Source={x:Static services:ThemeManager.Instance}, Path=CardBorder}"
                                        BorderThickness="0.5"
                                        MinHeight="120"
                                        Background="{Binding IsCurrentMonth, Converter={x:Static vm:CalendarMonthBackgroundConverter.Instance}}">
                                    <Border BorderBrush="#5B9BFF"
                                            BorderThickness="{Binding IsToday, Converter={x:Static vm:BoolToBorderThicknessConverter.Instance}}"
                                            CornerRadius="4">
                                        <Grid Margin="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Day number -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding DayNumber}"
                                                   Classes="day-number"
                                                   Classes.other-month="{Binding !IsCurrentMonth}"
                                                   Classes.today="{Binding IsToday}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Margin="2"/>

                                        <!-- Sessions -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                                            <ItemsControl ItemsSource="{Binding Sessions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:ScheduleItemWithSpacing">
                                                        <Border Classes="session-card month"
                                                                Classes.stu="{Binding Item.IsStu}"
                                                                Margin="0,1"
                                                                Height="16"
                                                                ToolTip.Tip="{Binding Item.DisplayName}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Item.StartKl, Converter={StaticResource TimeFormatConverter}}"
                                                                           FontSize="8"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextSecondary}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,2,0"/>

                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Item.DisplayName}"
                                                                           FontSize="8"
                                                                           FontWeight="Medium"
                                                                           Foreground="{Binding Source={x:Static services:ThemeManager.Instance}, Path=TextPrimary}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border IsVisible="{Binding IsLoading}"
                Background="#99000000"
                Grid.RowSpan="2">
            <TextBlock Text="Laster..."
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
